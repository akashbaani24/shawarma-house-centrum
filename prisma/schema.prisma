// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  businessName String   @default("Daily Report")
  password     String
  role         String   @default("USER") // "ADMIN" | "USER"
  rights       String   @default("[]")   // JSON array of allowed view keys
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdEntries      Entry[]
  createdOpeningBalances OpeningBalance[]
  createdDenominations   Denomination[]
  createdEntryTypes      EntryType[]
  createdBankAccounts    BankAccount[]
}

model BankAccount {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  bankName      String   // e.g. "EBL", "City Bank"
  accountName   String   // e.g. "Eventrum Main"
  accountNumber String   // e.g. "1234567890"
  branch        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries       Entry[]

  @@index([createdById])
}

model EntryType {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  name        String
  kind        String   // "INCOME" | "EXPENSE"
  createdAt   DateTime @default(now())

  @@unique([name, kind])
}

model Entry {
  id             String   @id @default(cuid())
  createdById    String?
  creator        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  typeId         String?
  kind           String   // "INCOME" | "EXPENSE"
  category       String
  amount         Float
  note           String?
  date           String   // YYYY-MM-DD
  paymentMethod  String   @default("CASH") // CASH | CARD | BANK | MOBILE_BANK
  bankAccountId  String?
  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([date])
  @@index([kind, date])
  @@index([createdById])
  @@index([paymentMethod])
}

model OpeningBalance {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date        String   // YYYY-MM-DD
  amount      Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
}

model Denomination {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date          String   // YYYY-MM-DD
  denomination  Int      // 1000, 500, 200, 100, 50, 20, 10, 5, 2, 1
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, denomination])
  @@index([date])
}
