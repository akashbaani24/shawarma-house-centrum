// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  businessName String   @default("Daily Report")
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  entries      Entry[]
}

model Entry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  section     String   // RECEIPTS | SALES | DENOMINATION | EXPENSES | ADVANCES | PAYMENTS | DEPOSITS
  particulars String   // label / denomination value as string
  amount      Float    @default(0)
  count       Int?     // for denomination only
  date        String   // YYYY-MM-DD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, section, particulars, date])
  @@index([userId, date])
  @@index([userId, section, date])
}
