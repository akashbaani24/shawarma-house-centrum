// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Literal file: URL — Prisma's engine validates this at build/runtime.
  // The actual Turso connection is handled by the PrismaLibSql adapter in
  // src/lib/db.ts, which reads DATABASE_URL (the libsql:// URL) directly.
  // Using a literal (not env()) means Prisma never reads DATABASE_URL here,
  // so DATABASE_URL can safely be a libsql:// URL for the adapter.
  url = "file:./prisma-local.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  businessName String   @default("Daily Report")
  password     String
  role         String   @default("USER") // "ADMIN" | "USER"
  rights       String   @default("[]")   // JSON array of allowed view keys
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdEntries      Entry[]
  createdOpeningBalances OpeningBalance[]
  createdDenominations   Denomination[]
  createdEntryTypes      EntryType[]
  createdBankAccounts    BankAccount[]
  createdPurchases       Purchase[]
  createdCustomers       Customer[]
}

model BankAccount {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  bankName      String   // e.g. "EBL", "City Bank"
  accountName   String   // e.g. "Eventrum Main"
  accountNumber String   // e.g. "1234567890"
  branch        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries       Entry[]

  @@index([createdById])
}

model EntryType {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  name        String
  kind        String   // "INCOME" | "EXPENSE"
  createdAt   DateTime @default(now())

  @@unique([name, kind])
}

model Entry {
  id                String   @id @default(cuid())
  createdById       String?
  creator           User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  typeId            String?
  kind              String   // "INCOME" | "EXPENSE" | "INVEST"
  category          String
  amount            Float    // Total amount of the transaction (bill amount or sale amount)
  dueAmount         Float    @default(0) // Accrual: amount still due/unpaid. 0 = fully paid. Positive = receivable/payable.
  note              String?
  date              String   // YYYY-MM-DD — the date the transaction OCCURRED (accrual basis)
  paymentDate       String?  // YYYY-MM-DD — when payment was actually made/received (null = not yet paid)
  paymentMethod     String   @default("CASH") // CASH | CARD | BANK | MOBILE_BANK | CREDIT
  source            String   @default("BRANCH") // BRANCH | OFFICE — BRANCH shows in Branch Daily Report, OFFICE only in Expense Details
  bankAccountId     String?
  bankAccount       BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  // Expense two-level dropdown: links to the main expense category + supplier
  expenseCategoryId String?
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  // Customer link — for credit sales (accrual: track who owes us)
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  @@index([date])
  @@index([kind, date])
  @@index([createdById])
  @@index([paymentMethod])
  @@index([source, date])
  @@index([supplierId, date])
  @@index([kind, source, date])
  @@index([customerId])
  @@index([dueAmount])
}

model OpeningBalance {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date        String   // YYYY-MM-DD
  amount      Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
}

model Denomination {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date          String   // YYYY-MM-DD
  denomination  Int      // 1000, 500, 200, 100, 50, 20, 10, 5, 2, 1
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, denomination])
  @@index([date])
}

model BusinessProfile {
  id        String   @id @default(cuid())
  logoUrl   String?
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   Entry[]
  bills     SupplierBill[]
  purchases Purchase[]

  @@unique([name])
}

// Main expense categories for the two-level dropdown.
// itemType determines what the second dropdown shows:
//   "TYPE"     → existing EntryType (expense heads)
//   "SUPPLIER" → Supplier names
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   // e.g. "Regular Expense", "Supplier Bill"
  itemType  String   @default("TYPE") // "TYPE" | "SUPPLIER"
  createdAt DateTime @default(now())

  entries   Entry[]

  @@unique([name])
}

model SupplierBill {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  billDate    String   // YYYY-MM-DD — the date on the supplier's bill
  billNumber  String?
  billAmount  Float
  paidAmount  Float    @default(0)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([supplierId])
  @@index([billDate])
}

// ============ Purchase Module ============
//
// A "Purchase" is a single procurement event from a supplier on a given
// date. Each purchase has one or more line items (PurchaseItem) covering
// the Item name, quantity, unit of measure (UoM), unit price, and
// computed total (qty × unitPrice).
//
// This is a standalone record — it does NOT automatically create an
// Entry or SupplierBill. The user can use this module to log purchases
// independently of the accounting entries, and later reconcile them
// with the expense / supplier-bill flow.

model Purchase {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseDate String  // YYYY-MM-DD
  invoiceNumber String? // optional supplier invoice / challan number
  note        String?
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PurchaseItem[]

  @@index([supplierId])
  @@index([purchaseDate])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  itemName    String
  qty         Float
  uom         String   // unit of measure: kg, pcs, ltr, box, etc.
  unitPrice   Float
  total       Float    // qty × unitPrice (stored to avoid recompute drift)
  createdAt   DateTime @default(now())

  @@index([purchaseId])
}

// ============ Accrual Basis: Customer (for Credit Sales) ============
//
// A Customer is someone who buys on credit. When a credit sale is made,
// an Entry is created with kind=INCOME, paymentMethod=CREDIT,
// dueAmount > 0, and customerId set. When the customer pays, a separate
// payment Entry can be created (kind=INCOME, paymentMethod=CASH/BANK,
// dueAmount=0) OR the original entry's dueAmount can be reduced.
//
// The Accounts Receivable report shows all customers with dueAmount > 0.

model Customer {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  name        String
  phone       String?
  address     String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     Entry[]

  @@unique([name])
}
