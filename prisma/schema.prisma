// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Literal file: URL — Prisma's engine validates this at build/runtime.
  // The actual Turso connection is handled by the PrismaLibSql adapter in
  // src/lib/db.ts, which reads DATABASE_URL (the libsql:// URL) directly.
  // Using a literal (not env()) means Prisma never reads DATABASE_URL here,
  // so DATABASE_URL can safely be a libsql:// URL for the adapter.
  url = "file:./prisma-local.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  businessName String   @default("Daily Report")
  password     String
  role         String   @default("USER") // "ADMIN" | "USER"
  rights       String   @default("[]")   // JSON array of allowed view keys
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdEntries      Entry[]
  createdOpeningBalances OpeningBalance[]
  createdDenominations   Denomination[]
  createdEntryTypes      EntryType[]
  createdBankAccounts    BankAccount[]
}

model BankAccount {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  bankName      String   // e.g. "EBL", "City Bank"
  accountName   String   // e.g. "Eventrum Main"
  accountNumber String   // e.g. "1234567890"
  branch        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries       Entry[]

  @@index([createdById])
}

model EntryType {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  name        String
  kind        String   // "INCOME" | "EXPENSE"
  createdAt   DateTime @default(now())

  @@unique([name, kind])
}

model Entry {
  id                String   @id @default(cuid())
  createdById       String?
  creator           User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  typeId            String?
  kind              String   // "INCOME" | "EXPENSE" | "INVEST"
  category          String
  amount            Float
  note              String?
  date              String   // YYYY-MM-DD
  paymentMethod     String   @default("CASH") // CASH | CARD | BANK | MOBILE_BANK
  source            String   @default("BRANCH") // BRANCH | OFFICE — BRANCH shows in Branch Daily Report, OFFICE only in Expense Details
  bankAccountId     String?
  bankAccount       BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  // Expense two-level dropdown: links to the main expense category + supplier
  expenseCategoryId String?
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  @@index([date])
  @@index([kind, date])
  @@index([createdById])
  @@index([paymentMethod])
}

model OpeningBalance {
  id          String   @id @default(cuid())
  createdById String?
  creator     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date        String   // YYYY-MM-DD
  amount      Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
}

model Denomination {
  id            String   @id @default(cuid())
  createdById   String?
  creator       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  date          String   // YYYY-MM-DD
  denomination  Int      // 1000, 500, 200, 100, 50, 20, 10, 5, 2, 1
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, denomination])
  @@index([date])
}

model BusinessProfile {
  id        String   @id @default(cuid())
  logoUrl   String?
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   Entry[]

  @@unique([name])
}

// Main expense categories for the two-level dropdown.
// itemType determines what the second dropdown shows:
//   "TYPE"     → existing EntryType (expense heads)
//   "SUPPLIER" → Supplier names
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   // e.g. "Regular Expense", "Supplier Bill"
  itemType  String   @default("TYPE") // "TYPE" | "SUPPLIER"
  createdAt DateTime @default(now())

  entries   Entry[]

  @@unique([name])
}
