# Turso (libsql) cloud database — used by src/lib/db.ts (PrismaLibSql adapter)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Prisma sqlite datasource URL — must be a file: URL (sqlite provider requirement).
# Read by the Prisma library engine for validation; the actual runtime connection
# uses Turso via the PrismaLibSql adapter (see src/lib/db.ts).
DATABASE_URL=file:./prisma-local.db

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-base64
NEXTAUTH_URL=http://localhost:3000
